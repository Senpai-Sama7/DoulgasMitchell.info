  "scripts": {
    "dev": "next dev --webpack -p 3000 2>&1 | tee dev.log",
    "build": "prisma generate && NODE_ENV=production next build && bun scripts/postbuild-standalone.mjs",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "prisma generate --schema=prisma/schema.sqlite.prisma && vitest run",
    "db:push": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:generate:prod": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "admin:check": "bun scripts/admin/check-admin.ts",
    "admin:reset": "bun scripts/admin/reset-admin.ts",
    "admin:test-login": "bun scripts/admin/test-login.ts",
    "admin:provision": "bun scripts/admin/provision-content.ts",
    "secret:generate": "bun scripts/generate-secret.mjs",
    "backup": "bun scripts/backup.mjs"
